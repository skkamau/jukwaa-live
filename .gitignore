# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!/backend/.env.example

# backend generated files
/backend/node_modules/
/backend/dist/
/backend/coverage/
/backend/src/generated/prisma/

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/

# TypeScript and Vite generated files
*.tsbuildinfo
/vite.config.js
/vite.config.d.ts

# Obsolete starter scaffold retained locally
/app/
/build/
/db/
/drizzle/
/examples/
/tests/
/worker/
