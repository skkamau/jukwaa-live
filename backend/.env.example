NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated exact origins. Wildcards are rejected.
# FRONTEND_ORIGINS=https://preview.example.com
DATABASE_URL=postgresql://jukwaa:jukwaa_dev_only@localhost:5432/jukwaa_dev
TRUST_PROXY=false
SESSION_TTL_DAYS=30
AUTH_COOKIE_SAME_SITE=lax
EMAIL_DELIVERY_MODE=console
ALLOW_PRELAUNCH_TEST_MODE=false
# Temporary switch: when true, every account is eligible for prelaunch self-activation.
ALLOW_ALL_PRELAUNCH_TEST_ACCOUNTS=false
PRELAUNCH_TEST_EMAILS=
ALLOW_PRELAUNCH_STREAM_SIMULATION=false
MAIL_FROM=Vyrlo <no-reply@jukwaa.live>
STREAMING_PROVIDER=mock
STREAM_STATUS_SYNC_SECONDS=10
# Required only for an intentional non-video production demo using the mock provider.
ALLOW_MOCK_STREAMING_IN_PRODUCTION=false
