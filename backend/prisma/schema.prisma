generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  VIEWER
  MODERATOR
  ADMIN
  SUPER_ADMIN

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED

  @@map("user_status")
}

enum CreatorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED

  @@map("creator_status")
}

enum ChannelStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED

  @@map("channel_status")
}

enum StreamStatus {
  PREPARING
  LIVE
  ENDED
  CANCELLED
  FAILED

  @@map("stream_status")
}

enum StreamingProviderType {
  MOCK
  LOCAL
  AMAZON_IVS

  @@map("streaming_provider_type")
}

model User {
  id              String          @id @default(uuid()) @db.Uuid
  email           String          @unique(map: "users_email_key") @db.VarChar(320)
  username        String          @unique(map: "users_username_key") @db.VarChar(50)
  displayName     String          @map("display_name") @db.VarChar(100)
  avatarUrl       String?         @map("avatar_url") @db.VarChar(2048)
  bio             String?         @db.VarChar(500)
  passwordHash    String?         @map("password_hash") @db.VarChar(255)
  role            UserRole        @default(VIEWER)
  status          UserStatus      @default(ACTIVE)
  emailVerifiedAt DateTime?       @map("email_verified_at") @db.Timestamptz(3)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(3)
  creatorProfile  CreatorProfile?
  authSessions    AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([status], map: "users_status_idx")
  @@index([createdAt], map: "users_created_at_idx")
  @@map("users")
}

model AuthSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique(map: "auth_sessions_token_hash_key") @map("token_hash") @db.Char(64)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)
  user       User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@index([userId, revokedAt], map: "auth_sessions_user_id_revoked_at_idx")
  @@map("auth_sessions")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique(map: "email_verification_tokens_token_hash_key") @map("token_hash") @db.Char(64)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "email_verification_tokens_user_id_idx")
  @@index([expiresAt], map: "email_verification_tokens_expires_at_idx")
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique(map: "password_reset_tokens_token_hash_key") @map("token_hash") @db.Char(64)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@index([expiresAt], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model CreatorProfile {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @unique(map: "creator_profiles_user_id_key") @map("user_id") @db.Uuid
  status     CreatorStatus @default(PENDING)
  verifiedAt DateTime?     @map("verified_at") @db.Timestamptz(3)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  user       User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  channel    Channel?

  @@index([status], map: "creator_profiles_status_idx")
  @@index([createdAt], map: "creator_profiles_created_at_idx")
  @@map("creator_profiles")
}

model Channel {
  id               String         @id @default(uuid()) @db.Uuid
  creatorProfileId String         @unique(map: "channels_creator_profile_id_key") @map("creator_profile_id") @db.Uuid
  slug             String         @unique(map: "channels_slug_key") @db.VarChar(80)
  name             String         @db.VarChar(100)
  description      String?        @db.VarChar(1000)
  bannerUrl        String?        @map("banner_url") @db.VarChar(2048)
  status           ChannelStatus  @default(ACTIVE)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz(3)
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  streamingConfig  StreamingChannelConfig?
  streams          Stream[]

  @@index([status], map: "channels_status_idx")
  @@index([createdAt], map: "channels_created_at_idx")
  @@map("channels")
}

model StreamingChannelConfig {
  id                String                @id @default(uuid()) @db.Uuid
  channelId         String                @unique(map: "streaming_channel_configs_channel_id_key") @map("channel_id") @db.Uuid
  provider          StreamingProviderType
  providerChannelId String?               @unique(map: "streaming_channel_configs_provider_channel_id_key") @map("provider_channel_id") @db.VarChar(255)
  ingestEndpoint    String?               @map("ingest_endpoint") @db.VarChar(2048)
  playbackUrl       String?               @map("playback_url") @db.VarChar(2048)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  channel           Channel               @relation(fields: [channelId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([provider], map: "streaming_channel_configs_provider_idx")
  @@map("streaming_channel_configs")
}

model Stream {
  id                String                @id @default(uuid()) @db.Uuid
  channelId         String                @map("channel_id") @db.Uuid
  title             String                @db.VarChar(140)
  description       String?               @db.VarChar(1000)
  category          String                @db.VarChar(80)
  language          String                @db.VarChar(40)
  tags              String[]              @default([])
  matureContent     Boolean               @default(false) @map("mature_content")
  status            StreamStatus          @default(PREPARING)
  streamingProvider StreamingProviderType @map("streaming_provider")
  providerStreamId  String?               @map("provider_stream_id") @db.VarChar(255)
  startedAt         DateTime?             @map("started_at") @db.Timestamptz(3)
  endedAt           DateTime?             @map("ended_at") @db.Timestamptz(3)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  channel           Channel               @relation(fields: [channelId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([channelId, createdAt], map: "streams_channel_id_created_at_idx")
  @@index([status, startedAt], map: "streams_status_started_at_idx")
  @@index([providerStreamId], map: "streams_provider_stream_id_idx")
  @@map("streams")
}
